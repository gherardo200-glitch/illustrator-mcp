{
  "name": "illustrator-mcp-server",
  "version": "0.1.0",
  "description": "MCP server to control Adobe Illustrator from Claude, ChatGPT, and any MCP client.",
  "type": "module",
  "bin": {
    "illustrator-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "dev": "tsc --watch",
    "validate": "npm run build && node scripts/validate.mjs",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "illustrator",
    "adobe-illustrator",
    "extendscript",
    "claude",
    "chatgpt",
    "automation",
    "design"
  ],
  "author": "gherardo200-glitch",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0"
  }
}
